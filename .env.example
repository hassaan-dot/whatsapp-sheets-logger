# WhatsApp group ID (format: xxxxx@g.us)
# Run with DISCOVERY_MODE=true first to find your group ID
TARGET_GROUP_ID=xxxxx@g.us

# Target user ID (format: 923xxxxxxxx@c.us)
# In groups, message.author is the sender's WhatsApp ID
TARGET_USER_ID=923xxxxxxxx@c.us

# Google Apps Script Web App URL (deploy as "Anyone with link")
WEBHOOK_URL=https://script.google.com/macros/s/xxxxx/exec

# Set to true on first run to print all group/user IDs to console
DISCOVERY_MODE=false

# Optional: path to Chrome/Chromium if Puppeteer fails to launch (macOS usually auto-detected)
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Remote setup (DigitalOcean / VPS): web page to scan QR in browser instead of terminal
# Generate a long random string, e.g. openssl rand -hex 32
# SETUP_TOKEN=your-secret-token-here
# SETUP_PORT=3099
